<Window x:Class="TransitionAuditioner.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="720" SizeToContent="Height"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{Binding ConnectCommand}"
                    Width="45" Height="35" VerticalAlignment="Center"
                    ToolTip="Connect to Wwise"
                    IsEnabled="{Binding CanConnect}">
                <Grid>
                    <TextBlock Style="{StaticResource FluentIcon}" Text="{Binding ConnectIcon}"
                               Visibility="{Binding ShowConnectionIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ProgressBar IsIndeterminate="True" Width="20" Height="20"
                                 Visibility="{Binding ShowConnectingProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Button>

            <Separator Grid.Column="1" Margin="10,0,10,0" />

            <Border Grid.Column="2" Padding="12,0" CornerRadius="6" Height="35"
                    Background="{DynamicResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                    VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <DockPanel>
                    <Image DockPanel.Dock="Left" Source="{Binding TargetIcon}"
                           Width="15" Height="15" Margin="0,0,8,0" VerticalAlignment="Center"
                           Visibility="{Binding HasTarget, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding TargetName}" FontSize="18" FontWeight="Medium"
                               VerticalAlignment="Center" HorizontalAlignment="Left"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding TargetName}" />
                </DockPanel>
            </Border>

            <Button Grid.Column="3" Width="45" Height="35" Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Command="{Binding PullSelectionCommand}"
                    ToolTip="{Binding PullSelectionToolTip}">
                <TextBlock Style="{StaticResource FluentIcon}" Text="{Binding PullSelectionIcon}" />
            </Button>

            <Separator Grid.Column="4" Margin="10,0,10,0" />

            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding ThemeChangeCommand}"
                        Width="45" Height="35" Margin="0,0,10,0"
                        ToolTip="Change app theme">
                    <TextBlock Style="{StaticResource FluentIcon}" Text="{Binding ThemeIcon}" />
                </Button>
                <Button Command="{Binding ToggleActivityCommand}"
                        Width="45" Height="35"
                        ToolTip="Toggle Activity log">
                    <TextBlock Style="{StaticResource FluentIcon}">&#xe8fd;</TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Cue offset from end (s)"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" Width="70" VerticalAlignment="Center"
                     Text="{Binding OffsetSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="3" Text="Length basis"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Grid.Column="4" Width="150" VerticalAlignment="Center"
                      SelectedIndex="{Binding LengthSourceIndex, Mode=TwoWay}">
                <ComboBoxItem Content="Exit cue" />
                <ComboBoxItem Content="Segment end" />
                <ComboBoxItem Content="Audio length" />
            </ComboBox>

            <Button Grid.Column="6" Content="Set Up &amp; Audition" Padding="14,6"
                    Command="{Binding SetUpCommand}" />
        </Grid>

        <TextBlock Grid.Row="2" Margin="0,16,0,6" Text="Activity" Opacity="0.6" FontSize="12"
                   Visibility="{Binding IsActivityVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border Grid.Row="3" Height="240" CornerRadius="6" BorderThickness="1" BorderBrush="#33808080"
                Visibility="{Binding IsActivityVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBox Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True" TextWrapping="Wrap"
                     Background="Transparent" BorderThickness="0"
                     VerticalScrollBarVisibility="Auto" />
        </Border>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Command="{Binding ShowInExplorerCommand}" Width="45" Height="35" Margin="0,0,8,0"
                        ToolTip="Show in Project Explorer">
                    <TextBlock Style="{StaticResource FluentIcon}">&#xE7AC;</TextBlock>
                </Button>
                <Button Command="{Binding OpenPlaylistEditorCommand}" Width="45" Height="35"
                        ToolTip="Open the Music Playlist Editor in Wwise">
                    <TextBlock Style="{StaticResource FluentIcon}">&#xE8A4;</TextBlock>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding PlayCommand}" Width="45" Height="35" Margin="0,0,8,0"
                        ToolTip="Play">
                    <TextBlock Style="{StaticResource FluentIcon}">&#xF5B0;</TextBlock>
                </Button>
                <Button Command="{Binding StopCommand}" Width="45" Height="35"
                        ToolTip="Stop">
                    <TextBlock Style="{StaticResource FluentIcon}">&#xEE95;</TextBlock>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Finish &amp; Clean Up"
                        Command="{Binding FinishCommand}" Padding="14,6" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
